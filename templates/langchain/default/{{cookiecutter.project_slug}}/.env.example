AGENTSEEK_MODEL={{ cookiecutter.default_model }}
AGENTSEEK_API_KEY=
AGENTSEEK_API_BASE=
AGENTSEEK_STREAM_OUTPUT=true
AGENTSEEK_AG_UI_PORT={{ cookiecutter.gateway_port }}
FRONTEND_PORT={{ cookiecutter.frontend_port }}
COPILOTKIT_PORT={{ cookiecutter.copilotkit_port }}
AGENTSEEK_AG_UI_AGENT_URL=http://127.0.0.1:{{ cookiecutter.gateway_port }}/agent

# Optional: Feishu channel
AGENTSEEK_FEISHU_APP_ID=
AGENTSEEK_FEISHU_APP_SECRET=
AGENTSEEK_FEISHU_VERIFICATION_TOKEN=
# AGENTSEEK_FEISHU_ENCRYPT_KEY=


# --- LangSmith (optional, for tracing) ------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="<your-langsmith-api-key>"
# Optional: customize the project name shown in LangSmith UI (defaults to "default").
# LANGSMITH_PROJECT=my-custom-project
