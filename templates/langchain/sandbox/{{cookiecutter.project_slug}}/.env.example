# --- Model + provider connection ------------------------------------------
# AgentSeek readiness checks read this file for declared lifecycle variables.
# The LangGraph backend also loads this file at runtime through python-dotenv.
#
# Choose one provider, then fill only that provider's API key block below.
AGENTSEEK_MODEL_PROVIDER={{ cookiecutter.default_model_provider }}
# The generated agent defaults to the scaffold-time model, but you can
# override it here without editing code.
AGENTSEEK_MODEL={{ cookiecutter.default_model }}
# If you switch providers, switch this model too. Examples:
# - openai: gpt-4.1-mini
# - anthropic: claude-3-5-sonnet-latest
# - google_genai: gemini-2.5-pro
# Compatibility aliases for AGENTSEEK_MODEL also work: BUB_MODEL, DEEPAGENTS_MODEL.

# OpenAI / OpenAI-compatible. Required when AGENTSEEK_MODEL_PROVIDER=openai.
# Leave OPENAI_API_BASE empty to use the official OpenAI endpoint.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Anthropic / Anthropic-compatible. Required when AGENTSEEK_MODEL_PROVIDER=anthropic.
# Leave ANTHROPIC_API_URL empty to use the official Anthropic endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=

# Gemini / Google-compatible. Required when AGENTSEEK_MODEL_PROVIDER=google_genai.
# Leave GOOGLE_API_BASE empty to use the official Gemini Developer API endpoint.
GOOGLE_API_KEY=
GOOGLE_API_BASE=

# Some OpenAI-compatible gateways emit large tool-call chunks with long gaps.
# Only used when AGENTSEEK_MODEL_PROVIDER=openai. Set to 0 to disable.
LANGCHAIN_OPENAI_STREAM_CHUNK_TIMEOUT_S=300

# --- LangSmith (required for sandbox + optional tracing) ------------------
# The LangSmith API key is used both for the sandbox backend and for tracing.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
# Optional: customize the project name shown in LangSmith UI (defaults to "default").
# LANGSMITH_PROJECT=my-sandbox-agent
