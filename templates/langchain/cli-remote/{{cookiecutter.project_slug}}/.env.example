# AgentSeek lifecycle commands read this file; Bub consumes the bridge variables.
BUB_MODEL={{ cookiecutter.default_model }}
BUB_API_KEY=
BUB_API_BASE=
BUB_LANGCHAIN_SPEC={{ cookiecutter.project_slug }}.gateway_binding:build_spec

# The bridge calls this LangGraph Agent Server.
LANGGRAPH_URL={{ cookiecutter.langgraph_url }}
LANGGRAPH_ASSISTANT_ID={{ cookiecutter.assistant_id }}
LANGGRAPH_THREAD_ON_SESSION=false

# When BUB_MODEL starts with "openai:", the project maps BUB_API_KEY
# and BUB_API_BASE to OpenAI-compatible environment variables if they are unset.
