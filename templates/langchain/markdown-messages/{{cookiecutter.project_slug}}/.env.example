# --- Model provider --------------------------------------------------------
# Fill exactly one credential pair.
#
# The lifecycle spec checks AGENTSEEK_API_KEY and accepts OPENAI_API_KEY as an
# alias. It does not inject env values into child processes.
#
# langgraph.json loads this file for the backend. agent.py then bridges
# AGENTSEEK_* to OPENAI_* when OPENAI_* is not already set, so either pair works
# for OpenAI-compatible providers.
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=

AGENTSEEK_API_KEY=
AGENTSEEK_API_BASE=
AGENTSEEK_MODEL={{ cookiecutter.default_model }}


# --- LangSmith (optional, for tracing) ------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="<your-langsmith-api-key>"
# Optional: customize the project name shown in LangSmith UI.
# LANGSMITH_PROJECT=my-custom-project
