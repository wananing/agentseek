# OpenVINO model paths
# Point these at local OpenVINO IR model directories.
# `agentseek doctor` checks that these values are configured, but it does not
# require the directories to exist or run conversion. Use `agentseek task models`
# to download and convert the default HuggingFace models.
LLM_MODEL_PATH={{ cookiecutter.llm_model_path }}
EMBEDDING_MODEL_PATH={{ cookiecutter.embedding_model_path }}

# OpenVINO inference device: CPU, GPU, or NPU.
OPENVINO_DEVICE={{ cookiecutter.device }}

# Maximum tokens generated by the local LLM.
MAX_NEW_TOKENS=512

# SeekDB vector store
# Start SeekDB with `agentseek task seekdb` or `docker compose up -d`.
SEEKDB_HOST=127.0.0.1
SEEKDB_PORT=2881
SEEKDB_USER=root
SEEKDB_PASSWORD=
SEEKDB_DB_NAME={{ cookiecutter.seekdb_db_name }}
VECTOR_TABLE_NAME={{ cookiecutter.vector_table_name }}

# LangSmith tracing is optional. Leave LANGSMITH_API_KEY empty unless tracing is
# enabled in your environment.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT={{ cookiecutter.project_slug }}
