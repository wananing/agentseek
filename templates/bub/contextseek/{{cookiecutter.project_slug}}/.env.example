# --- model ---
BUB_MODEL={{ cookiecutter.default_model }}
BUB_API_KEY=
BUB_OPENAI_API_KEY=
BUB_OPENAI_API_BASE=

# --- gateway ---
BUB_STREAM_OUTPUT=true
BUB_AG_UI_PORT={{ cookiecutter.gateway_port }}
BUB_AG_UI_AGENT_URL=http://127.0.0.1:{{ cookiecutter.gateway_port }}/agent

# --- frontend ---
FRONTEND_PORT={{ cookiecutter.frontend_port }}
COPILOTKIT_PORT={{ cookiecutter.copilotkit_port }}

# --- ctx server ---
CTX_SERVER_PORT={{ cookiecutter.ctx_server_port }}

# --- contextseek semantic memory ---
AGENTSEEK_CTX_STORAGE_BACKEND={{ cookiecutter.contextseek_storage_backend }}
AGENTSEEK_CTX_TENANT={{ cookiecutter.contextseek_tenant }}
AGENTSEEK_CTX_EVOLUTION_ENABLED=true

# --- SeekDB backend (default: embedded mode, data stored at SEEKDB_PATH) ---
# Embedded mode requires pyseekdb; built-in all-MiniLM-L6-v2 embedding is used automatically.
AGENTSEEK_CTX_SEEKDB_PATH=.contextseek/seekdb.db
# Server mode (optional): connect to a remote seekdb / OceanBase server
# AGENTSEEK_CTX_SEEKDB_HOST=
# AGENTSEEK_CTX_SEEKDB_PORT=2881
# AGENTSEEK_CTX_SEEKDB_DATABASE=contextseek

# --- OceanBase backend (set AGENTSEEK_CTX_STORAGE_BACKEND=oceanbase to activate) ---
# NOTE: AGENTSEEK_CTX_EMBEDDING_DIMS must be set to match your embedding model when using OceanBase.
# AGENTSEEK_CTX_OB_HOST=your_ob_host
# AGENTSEEK_CTX_OB_PORT=2881
# AGENTSEEK_CTX_OB_USER=your_ob_user
# AGENTSEEK_CTX_OB_PASSWORD=your_ob_password
# AGENTSEEK_CTX_OB_DB_NAME=contextseek
# AGENTSEEK_CTX_OB_TABLE_NAME=contextseek_items

# --- embedding model ---
# seekdb backend uses pyseekdb's built-in all-MiniLM-L6-v2 (384 dims, ONNX, no API key needed).
# Uncomment below to override with an external embedding provider (e.g. for OceanBase backend).
# AGENTSEEK_CTX_EMBEDDING_PROVIDER=langchain
# AGENTSEEK_CTX_EMBEDDING_CLASS_PATH=langchain_openai.OpenAIEmbeddings
# AGENTSEEK_CTX_EMBEDDING_MODEL=text-embedding-3-small
# AGENTSEEK_CTX_EMBEDDING_DIMS=1536
# AGENTSEEK_CTX_EMBEDDING_BASE_URL=

# --- LLM (auto-bridged from BUB_MODEL / BUB_API_KEY / BUB_OPENAI_API_BASE) ---
# No extra credentials needed; LLM_CLASS_PATH and LLM_MODEL are derived automatically.
AGENTSEEK_CTX_LLM_PROVIDER=langchain

# --- retrieval ---
AGENTSEEK_CTX_RETRIEVAL_DEFAULT_K=5
AGENTSEEK_CTX_RETRIEVAL_RECALL_ROUTES=["phrase","terms","vector"]
AGENTSEEK_CTX_RETRIEVAL_CANDIDATE_MULTIPLIER=4
AGENTSEEK_CTX_RETRIEVAL_VECTOR_WEIGHT=0.7
AGENTSEEK_CTX_RETRIEVAL_FTS_WEIGHT=0.3
AGENTSEEK_CTX_RETRIEVAL_RERANKER_MODE=heuristic

# --- summarizer ---
AGENTSEEK_CTX_SUMMARIZER_PROVIDER=llm
AGENTSEEK_CTX_SUMMARIZER_L2_MAX_CHARS=100
AGENTSEEK_CTX_SUMMARIZER_L1_MAX_CHARS=2000

# --- evolution ---
AGENTSEEK_CTX_EVOLUTION_DEDUPE_BY_HASH=true
AGENTSEEK_CTX_EVOLUTION_SEMANTIC_MERGE=true
AGENTSEEK_CTX_EVOLUTION_SEMANTIC_MERGE_THRESHOLD=0.72
AGENTSEEK_CTX_EVOLUTION_DECAY_HALF_LIFE_DAYS=7.0
AGENTSEEK_CTX_EVOLUTION_LLM_MERGE_ENABLED=true
AGENTSEEK_CTX_EVOLUTION_LLM_DISTILL_ENABLED=true

# --- dream ---
AGENTSEEK_CTX_DREAM_LLM_ENABLED=true

# --- observability ---
AGENTSEEK_CTX_OBSERVABILITY_AUDIT_ENABLED=true
AGENTSEEK_CTX_OBSERVABILITY_AUDIT_PATH=.contextseek/audit.jsonl
AGENTSEEK_CTX_OBSERVABILITY_METRICS_ENABLED=true
AGENTSEEK_CTX_OBSERVABILITY_METRICS_PATH=.contextseek/metrics.prom

# --- lifecycle ---
AGENTSEEK_CTX_LIFECYCLE_AUTO_COMPACT=true
AGENTSEEK_CTX_LIFECYCLE_COMPACT_MIN_ITEMS=5
AGENTSEEK_CTX_LIFECYCLE_INTERVAL_SECONDS=3600.0

# --- GIS (requires STORAGE_BACKEND=oceanbase with GIS support) ---
AGENTSEEK_CTX_GEO_ENABLED=true
AGENTSEEK_CTX_GEO_GEO_TABLE_NAME=contextseek_geo
AGENTSEEK_CTX_GEO_SRID=4326
AGENTSEEK_CTX_GEO_DEFAULT_RADIUS_KM=10.0
AGENTSEEK_CTX_GEO_WEIGHT=0.4
