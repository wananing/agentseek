# Runtime model used by the DeepAgents binding.
# Aliases accepted by the Python settings: AGENTSEEK_MODEL, DEEPAGENTS_MODEL.
BUB_MODEL={{ cookiecutter.default_model }}

# Provider credentials for OpenAI or OpenAI-compatible models.
# Aliases accepted by the Python settings: AGENTSEEK_API_KEY, OPENAI_API_KEY.
BUB_API_KEY=
# Optional OpenAI-compatible base URL.
# Aliases accepted by the Python settings: AGENTSEEK_API_BASE, OPENAI_API_BASE, OPENAI_BASE_URL.
BUB_API_BASE=

# LangChain binding loaded by the Bub gateway.
BUB_LANGCHAIN_SPEC={{ cookiecutter.project_slug }}.demo_binding:build_spec

# AG-UI gateway bind port. The public service and health check URLs are
# declared in .agentseek/lifecycle.toml.
BUB_AG_UI_PORT={{ cookiecutter._gateway_port }}
BUB_STREAM_OUTPUT=true
