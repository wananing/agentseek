# --- Model + provider connection ------------------------------------------
# Choose one provider, then fill only that provider's block below.
# AgentSeek reads this file for `agentseek doctor`; LangGraph also loads it
# because langgraph.json points at ./.env. Shell environment variables override
# values in this file.
AGENTSEEK_MODEL_PROVIDER={{ cookiecutter.default_model_provider }}
# The generated agent defaults to the scaffold-time model, but you can
# override it here without editing code.
AGENTSEEK_MODEL={{ cookiecutter.default_model }}
# If you switch providers, switch this model too. Examples:
# - openai: gpt-4.1-mini
# - anthropic: claude-3-5-sonnet-latest
# - google_genai: gemini-2.5-pro
# Compatibility aliases for AGENTSEEK_MODEL also work: DEEPAGENTS_MODEL, BUB_MODEL.

# OpenAI / OpenAI-compatible
# Leave OPENAI_API_BASE empty to use the official OpenAI endpoint.
# `agentseek doctor` accepts BUB_OPENAI_API_KEY as an alias for OPENAI_API_KEY.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Anthropic / Anthropic-compatible
# Leave ANTHROPIC_API_URL empty to use the official Anthropic endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=

# Gemini / Google-compatible
# Leave GOOGLE_API_BASE empty to use the official Gemini Developer API endpoint.
GOOGLE_API_KEY=
GOOGLE_API_BASE=

# Some OpenAI-compatible gateways emit large tool-call chunks with long gaps.
# Only used when AGENTSEEK_MODEL_PROVIDER=openai. Set to 0 to disable.
LANGCHAIN_OPENAI_STREAM_CHUNK_TIMEOUT_S=300

# --- Subagent model override -----------------------------------------------
# Override the model name used by all subagents (e.g. the researcher).
# Subagents share the same provider and base URL as the main model —
# only the model name differs. When blank, subagents use the same model
# as the main agent (or the per-subagent model in subagents.yaml).
# Examples: gpt-4.1-mini, claude-haiku-4-5-20251001, gemini-2.5-flash
AGENTSEEK_SUBAGENT_MODEL=

# --- Image generation (Gemini) --------------------------------------------
# Uses GOOGLE_API_KEY and GOOGLE_API_BASE above. Override the image model
# if needed (must be a Gemini model that supports image generation).
GOOGLE_IMAGE_MODEL={{ cookiecutter.google_image_model }}

# --- Tavily (required for researcher subagent) -----------------------------
# Get a key at https://app.tavily.com — the free tier is enough.
# Without this key, researcher web_search tool calls return an error.
TAVILY_API_KEY=

# --- LangSmith (optional, for tracing) ------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
# Optional: customize the project name shown in LangSmith UI (defaults to "default").
# LANGSMITH_PROJECT=my-custom-project
