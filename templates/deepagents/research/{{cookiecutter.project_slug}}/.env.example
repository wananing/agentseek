# --- Model provider --------------------------------------------------------
# Choose one provider, then fill only that provider's credential block below.
AGENTSEEK_MODEL_PROVIDER={{ cookiecutter.default_model_provider }}
AGENTSEEK_MODEL={{ cookiecutter.default_model }}
# If you switch providers, switch the model id too. Examples:
# - openai: gpt-4.1-mini
# - anthropic: claude-3-5-sonnet-latest
# - google_genai: gemini-2.5-pro
# Compatibility aliases for AGENTSEEK_MODEL also work: DEEPAGENTS_MODEL, BUB_MODEL.

# OpenAI / OpenAI-compatible
# Leave OPENAI_API_BASE empty for the official OpenAI endpoint.
OPENAI_API_KEY=
OPENAI_API_BASE=

# Anthropic / Anthropic-compatible
# Leave ANTHROPIC_API_URL empty for the official Anthropic endpoint.
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=

# Gemini / Google-compatible
# Leave GOOGLE_API_BASE empty for the official Gemini Developer API endpoint.
GOOGLE_API_KEY=
GOOGLE_API_BASE=

# Some OpenAI-compatible gateways emit large tool-call chunks with long gaps.
# Only used when AGENTSEEK_MODEL_PROVIDER=openai. Set to 0 to disable.
LANGCHAIN_OPENAI_STREAM_CHUNK_TIMEOUT_S=300

# --- Tavily ---------------------------------------------------------------
# Get a key at https://app.tavily.com — the free tier is enough for the
# verification probes in this template's README.
TAVILY_API_KEY=

# --- LangSmith tracing ----------------------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
# Optional: customize the project name shown in LangSmith UI.
# LANGSMITH_PROJECT=my-custom-project
