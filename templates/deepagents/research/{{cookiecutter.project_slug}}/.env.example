# --- Pick ONE pair for the model ------------------------------------------
# init_chat_model("openai:<id>") reads OPENAI_*. The bridge at the top of
# agent.py copies AGENTSEEK_* over when only the latter are set. Both pairs
# work with any OpenAI-compatible endpoint — point OPENAI_API_BASE (or
# AGENTSEEK_API_BASE) at your provider.
OPENAI_API_KEY=
OPENAI_API_BASE=

AGENTSEEK_API_KEY=
AGENTSEEK_API_BASE=

# Some OpenAI-compatible gateways emit large tool-call chunks with long gaps.
# Raise this if nested sub-agent runs time out mid-stream. Set to 0 to disable.
LANGCHAIN_OPENAI_STREAM_CHUNK_TIMEOUT_S=300

# --- Tavily (required for tavily_search) ---------------------------------
# Get a key at https://app.tavily.com — the free tier is enough for the
# verification probes in this template's README.
TAVILY_API_KEY=


# --- LangSmith (optional, for tracing) ------------------------------------
# Enable LangSmith tracing to inspect agent runs, token usage, and latency.
# Get an API key at https://smith.langchain.com/settings/apikeys
LANGSMITH_TRACING=true
LANGSMITH_API_KEY="<your-langsmith-api-key>"
# Optional: customize the project name shown in LangSmith UI (defaults to "default").
# LANGSMITH_PROJECT=my-custom-project
